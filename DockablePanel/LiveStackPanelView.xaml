<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:NinaLiveStack.DockablePanel">

    <BooleanToVisibilityConverter x:Key="BoolToVis" />

    <DataTemplate x:Key="NinaLiveStack.DockablePanel.LiveStackPanelVM_Dockable">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Row 0: Buttons -->
            <WrapPanel Grid.Row="0" Margin="4,4,4,1">
                <Button Content="Start" Command="{Binding StartCommand}" Margin="2" Padding="10,4" FontSize="11" ToolTip="Begin live stacking" />
                <Button Content="Stop" Command="{Binding StopCommand}" Margin="2" Padding="10,4" FontSize="11" ToolTip="Stop stacking and cancel plate solving" />
                <Button Content="Reset" Command="{Binding ResetCommand}" Margin="2" Padding="10,4" FontSize="11" ToolTip="Clear all frames and start fresh" />
                <Button Content="Full" Command="{Binding FullScreenCommand}" Margin="2" Padding="10,4" FontSize="11" ToolTip="Toggle fullscreen presentation window" />
                <Button Content="Save" Command="{Binding SaveStackCommand}" Margin="2" Padding="10,4" FontSize="11" ToolTip="Save stacked image as 32-bit FITS" />
                <Button Content="Load" Command="{Binding LoadFilesCommand}" Margin="2" Padding="10,4" FontSize="11" ToolTip="Load FITS files from disk" />
                <Button Content="Dark" Command="{Binding LoadDarkCommand}" Margin="2" Padding="10,4" FontSize="11" ToolTip="Load master dark frame for calibration" />
                <Button Content="Flat" Command="{Binding LoadFlatCommand}" Margin="2" Padding="10,4" FontSize="11" ToolTip="Load master flat frame for calibration" />
                <Button Content="Clr Cal" Command="{Binding ClearCalibrationCommand}" Margin="2" Padding="10,4" FontSize="11" ToolTip="Clear dark and flat calibration frames" />
            </WrapPanel>

            <!-- Row 1: Status + compact toggle grid -->
            <StackPanel Grid.Row="1" Margin="6,2">
                <TextBlock Text="{Binding StatusText, Mode=OneWay}" FontSize="11" TextTrimming="CharacterEllipsis" />
                <TextBlock Text="{Binding CalibrationStatus, Mode=OneWay}" FontSize="9" Foreground="#88CC88" />

                <!-- Compact toggle grid: label above checkbox -->
                <Grid Margin="0,4,0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Align" FontSize="9" Foreground="White" HorizontalAlignment="Center" Margin="0,0,10,1" />
                    <CheckBox  Grid.Row="1" Grid.Column="0" IsChecked="{Binding AlignmentEnabled}" HorizontalAlignment="Center" Margin="0,0,10,0"
                               ToolTip="Enable frame-to-frame alignment via star matching and plate solving" />

                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Hot Px" FontSize="9" Foreground="White" HorizontalAlignment="Center" Margin="0,0,10,1" />
                    <CheckBox  Grid.Row="1" Grid.Column="1" IsChecked="{Binding EnableHotPixelFilter}" HorizontalAlignment="Center" Margin="0,0,10,0"
                               ToolTip="Remove hot and cold pixels from each frame before stacking" />

                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Trail" FontSize="9" Foreground="White" HorizontalAlignment="Center" Margin="0,0,10,1" />
                    <CheckBox  Grid.Row="1" Grid.Column="2" IsChecked="{Binding EnableTrailMask}" HorizontalAlignment="Center" Margin="0,0,10,0"
                               ToolTip="Mask satellite trails at 15σ above background" />

                    <TextBlock Grid.Row="0" Grid.Column="3" Text="Arcsinh" FontSize="9" Foreground="White" HorizontalAlignment="Center" Margin="0,0,10,1" />
                    <CheckBox  Grid.Row="1" Grid.Column="3" IsChecked="{Binding UseArcsinhStretch}" HorizontalAlignment="Center" Margin="0,0,10,0"
                               ToolTip="Use arcsinh stretch (preserves color across brightness range)" />

                    <TextBlock Grid.Row="0" Grid.Column="4" Text="BG Sub" FontSize="9" Foreground="White" HorizontalAlignment="Center" Margin="0,0,10,1" />
                    <CheckBox  Grid.Row="1" Grid.Column="4" IsChecked="{Binding EnableBackgroundSub}" HorizontalAlignment="Center" Margin="0,0,10,0"
                               ToolTip="Subtract gradient background in linear space before stretching" />

                    <TextBlock Grid.Row="0" Grid.Column="5" Text="Broadcast" FontSize="9" Foreground="#88CCFF" HorizontalAlignment="Center" Margin="0,0,0,1" />
                    <CheckBox  Grid.Row="1" Grid.Column="5" IsChecked="{Binding UploadEnabled}" HorizontalAlignment="Center"
                               IsEnabled="{Binding BroadcastAvailable}"
                               ToolTip="{Binding BroadcastTooltip}" />

                    <!-- Settings gear button in the remaining space -->
                    <Button Grid.Row="0" Grid.RowSpan="2" Grid.Column="6" Content="⚙" Command="{Binding SettingsCommand}"
                            HorizontalAlignment="Right" VerticalAlignment="Center"
                            Padding="6,2" FontSize="14" ToolTip="Plugin settings (R2 credentials, overlay text)" />
                </Grid>
            </StackPanel>

            <!-- Row 2: Align + SNR + bad frame + solver status -->
            <StackPanel Grid.Row="2" Margin="6,0">
                <TextBlock Text="{Binding PlateSolverStatus, Mode=OneWay}" FontSize="9" Foreground="#DDAA44" TextTrimming="CharacterEllipsis" />
                <TextBlock Text="{Binding AlignStatus, Mode=OneWay}" FontSize="9" Foreground="Gray" TextTrimming="CharacterEllipsis" />
                <TextBlock Text="{Binding SNRStatus, Mode=OneWay}" FontSize="9" Foreground="#88AAFF" FontFamily="Consolas" TextTrimming="CharacterEllipsis" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding BadFrameStatus, Mode=OneWay}" FontSize="9" Foreground="#FFAA44" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                    <Button Grid.Column="1" Content="Rebuild" Command="{Binding RebuildCommand}" Padding="8,1" FontSize="10" Margin="4,0,0,0" />
                </Grid>
                <TextBlock Text="{Binding UploadStatus, Mode=OneWay}" FontSize="9" Foreground="#88CCFF" TextTrimming="CharacterEllipsis"
                           Visibility="{Binding UploadEnabled, Converter={StaticResource BoolToVis}}" />
            </StackPanel>

            <!-- Row 3: Adjustments -->
            <Border Grid.Row="3" Margin="4,2" Padding="4" BorderThickness="1" BorderBrush="Gray" CornerRadius="2">
                <StackPanel>
                    <!-- Always visible: header + stretch factor -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Adjust" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="White" />
                        <StackPanel Grid.Column="1" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Auto Stretch" Command="{Binding RecomputeStretchCommand}" Padding="8,1" FontSize="10" Margin="0,0,4,0" />
                            <Button Content="Reset All" Command="{Binding ResetStretchCommand}" Padding="8,1" FontSize="10" />
                        </StackPanel>
                    </Grid>
                    <Grid Margin="0,2,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="38" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Stretch Factor" FontSize="10" VerticalAlignment="Center" Foreground="White" ToolTip="Arcsinh stretch intensity — higher values reveal fainter detail" />
                        <Slider Grid.Column="1" Minimum="1" Maximum="500" Value="{Binding ArcsinhFactor}" SmallChange="5" Height="18" ToolTip="Arcsinh stretch intensity" />
                        <TextBlock Grid.Column="2" Text="{Binding ArcsinhFactor, StringFormat='{}{0:F0}'}" FontSize="9" VerticalAlignment="Center" HorizontalAlignment="Right" Foreground="White" />
                    </Grid>

                    <!-- Advanced: collapsed by default -->
                    <Expander Header="Advanced" FontSize="10" Foreground="Gray" Margin="0,4,0,0" IsExpanded="False">
                        <Grid Margin="0,4,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="38" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Brightness" FontSize="10" VerticalAlignment="Center" Foreground="White" ToolTip="Shift midtone brightness up or down" />
                            <Slider Grid.Row="0" Grid.Column="1" Minimum="-0.5" Maximum="0.5" Value="{Binding Brightness}" SmallChange="0.01" Height="18" ToolTip="Shift midtone brightness" />
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding Brightness, StringFormat='{}{0:F2}'}" FontSize="9" VerticalAlignment="Center" HorizontalAlignment="Right" Foreground="White" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Contrast" FontSize="10" VerticalAlignment="Center" Foreground="White" ToolTip="Adjust black point aggressiveness" />
                            <Slider Grid.Row="1" Grid.Column="1" Minimum="-0.02" Maximum="0.04" Value="{Binding Contrast}" SmallChange="0.001" Height="18" ToolTip="Adjust contrast/black point" />
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding Contrast, StringFormat='{}{0:F3}'}" FontSize="9" VerticalAlignment="Center" HorizontalAlignment="Right" Foreground="White" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Black Clip" FontSize="10" VerticalAlignment="Center" Foreground="White" ToolTip="Clip darkest pixels to pure black — hides faint noise" />
                            <Slider Grid.Row="2" Grid.Column="1" Minimum="0" Maximum="0.3" Value="{Binding BlackClip}" SmallChange="0.005" Height="18" ToolTip="Clip dark pixels to black" />
                            <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding BlackClip, StringFormat='{}{0:F2}'}" FontSize="9" VerticalAlignment="Center" HorizontalAlignment="Right" Foreground="White" />

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Red Balance" FontSize="10" VerticalAlignment="Center" Foreground="#FF6666" ToolTip="Scale red channel intensity" />
                            <Slider Grid.Row="3" Grid.Column="1" Minimum="0.5" Maximum="1.5" Value="{Binding RBalance}" SmallChange="0.02" Height="18" ToolTip="Red channel multiplier" />
                            <TextBlock Grid.Row="3" Grid.Column="2" Text="{Binding RBalance, StringFormat='{}{0:F2}'}" FontSize="9" VerticalAlignment="Center" HorizontalAlignment="Right" Foreground="#FF6666" />

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Green Balance" FontSize="10" VerticalAlignment="Center" Foreground="#66FF66" ToolTip="Scale green channel intensity" />
                            <Slider Grid.Row="4" Grid.Column="1" Minimum="0.5" Maximum="1.5" Value="{Binding GBalance}" SmallChange="0.02" Height="18" ToolTip="Green channel multiplier" />
                            <TextBlock Grid.Row="4" Grid.Column="2" Text="{Binding GBalance, StringFormat='{}{0:F2}'}" FontSize="9" VerticalAlignment="Center" HorizontalAlignment="Right" Foreground="#66FF66" />

                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Blue Balance" FontSize="10" VerticalAlignment="Center" Foreground="#6666FF" ToolTip="Scale blue channel intensity" />
                            <Slider Grid.Row="5" Grid.Column="1" Minimum="0.5" Maximum="1.5" Value="{Binding BBalance}" SmallChange="0.02" Height="18" ToolTip="Blue channel multiplier" />
                            <TextBlock Grid.Row="5" Grid.Column="2" Text="{Binding BBalance, StringFormat='{}{0:F2}'}" FontSize="9" VerticalAlignment="Center" HorizontalAlignment="Right" Foreground="#6666FF" />

                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Star Reduce" FontSize="10" VerticalAlignment="Center" Foreground="White" ToolTip="Shrink stars detected on linear data — preserves nebula detail" />
                            <Slider Grid.Row="6" Grid.Column="1" Minimum="0" Maximum="1" Value="{Binding StarReduction}" SmallChange="0.05" Height="18" ToolTip="Star reduction amount" />
                            <TextBlock Grid.Row="6" Grid.Column="2" Text="{Binding StarReduction, StringFormat='{}{0:F2}'}" FontSize="9" VerticalAlignment="Center" HorizontalAlignment="Right" Foreground="White" />

                            <!-- Crop with lock toggle -->
                            <StackPanel Grid.Row="7" Grid.Column="0" Orientation="Horizontal" ToolTip="Crop edges — lock keeps aspect ratio, unlock adjusts each side independently">
                                <TextBlock Text="Crop" FontSize="10" VerticalAlignment="Center" Foreground="#CCAA55" />
                                <CheckBox IsChecked="{Binding CropLocked}" Margin="4,0,0,0" VerticalAlignment="Center" ToolTip="Lock aspect ratio" />
                                <TextBlock Text="🔒" FontSize="8" VerticalAlignment="Center" Foreground="#CCAA55" Margin="2,0,0,0" />
                            </StackPanel>
                            <Slider Grid.Row="7" Grid.Column="1" Minimum="0" Maximum="0.3" Value="{Binding CropAll}" SmallChange="0.005" Height="18"
                                    Visibility="{Binding CropLocked, Converter={StaticResource BoolToVis}}" ToolTip="Crop all edges equally" />
                            <TextBlock Grid.Row="7" Grid.Column="2" Text="{Binding CropAll, StringFormat='{}{0:P0}'}" FontSize="9" VerticalAlignment="Center" HorizontalAlignment="Right" Foreground="#CCAA55"
                                       Visibility="{Binding CropLocked, Converter={StaticResource BoolToVis}}" />

                            <TextBlock Grid.Row="8" Grid.Column="0" Text="Crop Left" FontSize="10" VerticalAlignment="Center" Foreground="#CCAA55"
                                       Visibility="{Binding CropUnlocked, Converter={StaticResource BoolToVis}}" />
                            <Slider Grid.Row="8" Grid.Column="1" Minimum="0" Maximum="0.3" Value="{Binding CropLeft}" SmallChange="0.005" Height="18"
                                    Visibility="{Binding CropUnlocked, Converter={StaticResource BoolToVis}}" />
                            <TextBlock Grid.Row="8" Grid.Column="2" Text="{Binding CropLeft, StringFormat='{}{0:P0}'}" FontSize="9" VerticalAlignment="Center" HorizontalAlignment="Right" Foreground="#CCAA55"
                                       Visibility="{Binding CropUnlocked, Converter={StaticResource BoolToVis}}" />

                            <TextBlock Grid.Row="9" Grid.Column="0" Text="Crop Right" FontSize="10" VerticalAlignment="Center" Foreground="#CCAA55"
                                       Visibility="{Binding CropUnlocked, Converter={StaticResource BoolToVis}}" />
                            <Slider Grid.Row="9" Grid.Column="1" Minimum="0" Maximum="0.3" Value="{Binding CropRight}" SmallChange="0.005" Height="18"
                                    Visibility="{Binding CropUnlocked, Converter={StaticResource BoolToVis}}" />
                            <TextBlock Grid.Row="9" Grid.Column="2" Text="{Binding CropRight, StringFormat='{}{0:P0}'}" FontSize="9" VerticalAlignment="Center" HorizontalAlignment="Right" Foreground="#CCAA55"
                                       Visibility="{Binding CropUnlocked, Converter={StaticResource BoolToVis}}" />

                            <TextBlock Grid.Row="10" Grid.Column="0" Text="Crop Top" FontSize="10" VerticalAlignment="Center" Foreground="#CCAA55"
                                       Visibility="{Binding CropUnlocked, Converter={StaticResource BoolToVis}}" />
                            <Slider Grid.Row="10" Grid.Column="1" Minimum="0" Maximum="0.3" Value="{Binding CropTop}" SmallChange="0.005" Height="18"
                                    Visibility="{Binding CropUnlocked, Converter={StaticResource BoolToVis}}" />
                            <TextBlock Grid.Row="10" Grid.Column="2" Text="{Binding CropTop, StringFormat='{}{0:P0}'}" FontSize="9" VerticalAlignment="Center" HorizontalAlignment="Right" Foreground="#CCAA55"
                                       Visibility="{Binding CropUnlocked, Converter={StaticResource BoolToVis}}" />

                            <TextBlock Grid.Row="11" Grid.Column="0" Text="Crop Bottom" FontSize="10" VerticalAlignment="Center" Foreground="#CCAA55"
                                       Visibility="{Binding CropUnlocked, Converter={StaticResource BoolToVis}}" />
                            <Slider Grid.Row="11" Grid.Column="1" Minimum="0" Maximum="0.3" Value="{Binding CropBottom}" SmallChange="0.005" Height="18"
                                    Visibility="{Binding CropUnlocked, Converter={StaticResource BoolToVis}}" />
                            <TextBlock Grid.Row="11" Grid.Column="2" Text="{Binding CropBottom, StringFormat='{}{0:P0}'}" FontSize="9" VerticalAlignment="Center" HorizontalAlignment="Right" Foreground="#CCAA55"
                                       Visibility="{Binding CropUnlocked, Converter={StaticResource BoolToVis}}" />
                        </Grid>
                    </Expander>
                </StackPanel>
            </Border>

            <!-- Row 4: Image -->
            <Border Grid.Row="4" Margin="4,1" Background="Black" BorderThickness="1" BorderBrush="Gray" ClipToBounds="True">
                <Image Source="{Binding DisplayImage}" Stretch="Uniform" RenderTransformOrigin="0.5,0.5">
                    <Image.RenderTransform>
                        <ScaleTransform ScaleX="{Binding PanelZoom}" ScaleY="{Binding PanelZoom}" />
                    </Image.RenderTransform>
                </Image>
            </Border>

            <!-- Row 5: Info + Histogram + Zoom -->
            <Grid Grid.Row="5" Margin="4,1,4,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding FrameCount, StringFormat='Frames: {0}'}" FontSize="10" Margin="2,0,10,0" />
                    <TextBlock Text="{Binding MemoryUsageMB, StringFormat='{}{0:F0} MB'}" FontSize="10" />
                </StackPanel>
                <Image Grid.Column="1" Source="{Binding HistogramImage}" Stretch="Fill" Height="40" Margin="8,0" VerticalAlignment="Center" />
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="-" Command="{Binding ZoomOutCommand}" Padding="6,2" FontSize="14" FontWeight="Bold" Margin="1" />
                    <Button Content="Fit" Command="{Binding ZoomFitCommand}" Padding="6,2" FontSize="10" Margin="1" />
                    <Button Content="+" Command="{Binding ZoomInCommand}" Padding="6,2" FontSize="14" FontWeight="Bold" Margin="1" />
                </StackPanel>
            </Grid>
        </Grid>
    </DataTemplate>
</ResourceDictionary>
